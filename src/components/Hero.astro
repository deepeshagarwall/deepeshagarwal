---
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background: dot grid -->
  <div class="absolute inset-0 dot-grid opacity-30 pointer-events-none"></div>

  <!-- Background: radial gold glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] rounded-full pointer-events-none"
    style="background: radial-gradient(ellipse at center, rgba(245,166,35,0.07) 0%, transparent 70%);">
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center pt-24 pb-20">
    <!-- Avatar -->
    <div class="mb-8 flex justify-center">
      <div class="relative">
        <div class="w-28 h-28 sm:w-32 sm:h-32 rounded-full p-[3px]" style="background: linear-gradient(135deg, #F5A623, #FDD27A, #C47D0E);">
          <img
            src="/avatar.jpg"
            alt="Deepesh Agarwal"
            width="128"
            height="128"
            class="w-full h-full rounded-full object-cover object-top"
          />
        </div>
        <!-- Online dot -->
        <span class="absolute bottom-1 right-1 w-4 h-4 rounded-full bg-gold-400 border-2 border-surface-900 animate-pulse"></span>
      </div>
    </div>

    <!-- Pre-label row -->
    <div class="mb-4 flex flex-col sm:flex-row flex-wrap items-center justify-center gap-2 sm:gap-3">
      <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full border border-surface-600 bg-surface-800/60 backdrop-blur-sm">
        <span class="w-2 h-2 rounded-full bg-gold-400 animate-pulse"></span>
        <span class="font-mono text-xs text-muted tracking-widest uppercase">Technical Lead · L'Oréal</span>
      </div>
      <div class="inline-flex items-center gap-2 px-3 py-2 rounded-full border border-surface-600 bg-surface-800/60 backdrop-blur-sm">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="2"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
        <span class="font-mono text-xs text-muted tracking-widest uppercase">Hyderabad, India</span>
      </div>
      <div class="inline-flex items-center gap-2 px-3 py-2 rounded-full border border-green-500/30 bg-green-500/5 backdrop-blur-sm">
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        <span class="font-mono text-xs text-green-400 tracking-widest uppercase">Open for collaborations</span>
      </div>
    </div>

    <!-- Name -->
    <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold tracking-tight text-[#E8E8E8] mb-4 leading-none">
      Deepesh<br />
      <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(135deg, #F5A623 0%, #FDD27A 50%, #F5A623 100%);">
        Agarwal
      </span>
    </h1>

    <!-- Tagline -->
    <p class="mt-6 text-xl sm:text-2xl font-light text-muted italic">
      "Learning compounds."
    </p>

    <!-- Sub-tagline -->
    <p class="mt-4 max-w-2xl mx-auto text-base sm:text-lg text-[#888] leading-relaxed">
      I build cloud platforms and data systems — and study the systems that drive markets, decisions, and human growth.
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#projects"
        class="px-6 py-3 rounded-xl bg-gold-400 text-surface-900 font-semibold text-sm hover:bg-gold-300 transition-colors duration-200"
      >
        View My Work
      </a>
      <a
        href="#contact"
        class="px-6 py-3 rounded-xl border border-surface-500 text-[#E8E8E8] font-medium text-sm hover:border-gold-400 hover:text-gold-400 transition-colors duration-200"
      >
        Get in Touch
      </a>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 scroll-chevron opacity-40">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 9l6 6 6-6"/>
    </svg>
  </div>
</section>

<style>
  .dot-grid {
    background-image: radial-gradient(circle, #333 1px, transparent 1px);
    background-size: 28px 28px;
  }
  .scroll-chevron {
    animation: bounce 2s ease-in-out infinite;
  }
  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }
</style>
