  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2">
      <div class="w-7 h-7 rounded-md bg-gold-400 flex items-center justify-center text-surface-900 font-bold text-xs">
        DA
      </div>
      <span class="text-sm text-muted">Deepesh Agarwal</span>
    </div>

    <p class="font-mono text-xs text-muted text-center">
      Learning compounds. Always.
    </p>

    <p class="text-xs text-muted">© {year} · Built with Astro & Tailwind</p>
  </div>
</footer>
