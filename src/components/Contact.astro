---
const links = [
  {
    label: "Email",
    value: "contact@deepeshagarwal.com",
    href: "mailto:contact@deepeshagarwal.com",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  },
  {
    label: "LinkedIn",
    value: "linkedin.com/in/deepeshagrwal",
    href: "https://www.linkedin.com/in/deepeshagrwal/",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`,
  },
];
---

<section id="contact" class="py-28 px-6 bg-surface-800/30">
  <div class="max-w-6xl mx-auto">
    <!-- Section label -->
    <div class="mb-12">
      <p class="section-label"><span class="gold-line"></span>Contact</p>
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-start">
      <!-- Left: CTA -->
      <div>
        <h2 class="text-2xl sm:text-4xl font-bold text-[#E8E8E8] mb-4 leading-tight">
          Let's build something<br />
          <span class="text-gold-400">meaningful together.</span>
        </h2>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-green-500/30 bg-green-500/5 mb-4">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
          <span class="font-mono text-xs text-green-400 tracking-widest uppercase">Open for collaborations</span>
        </div>
        <p class="text-[#888] text-base leading-relaxed max-w-md">
          Whether it's a data engineering challenge, a cloud architecture question, an AI idea,
          a trading tools collaboration, or just a good conversation — I'm always happy to connect.
        </p>

        <a
          href="mailto:contact@deepeshagarwal.com"
          class="mt-8 inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gold-400 text-surface-900 font-semibold text-sm hover:bg-gold-300 transition-colors duration-200"
        >
          Say hello →
        </a>
      </div>

      <!-- Right: links -->
      <div class="space-y-4">
        {links.map(link => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="card flex items-center gap-4 p-5 group hover:border-gold-400/30 transition-all"
          >
            <div class="w-10 h-10 rounded-lg bg-surface-700 flex items-center justify-center text-muted group-hover:text-gold-400 group-hover:bg-gold-400/10 transition-colors">
              <Fragment set:html={link.icon} />
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-xs text-muted mb-0.5">{link.label}</div>
              <div class="text-sm text-[#E8E8E8] truncate">{link.value}</div>
            </div>
            <svg class="w-4 h-4 text-muted group-hover:text-gold-400 transition-colors flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M7 17L17 7M17 7H7M17 7v10"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
