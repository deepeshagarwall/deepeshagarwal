---
---

<section id="projects" class="py-28 px-6">
  <div class="max-w-6xl mx-auto">
    <!-- Section label -->
    <div class="mb-12">
      <p class="section-label"><span class="gold-line"></span>Projects</p>
      <h2 class="mt-3 text-3xl font-bold text-[#E8E8E8]">What I'm Building</h2>
    </div>

    <div class="grid lg:grid-cols-3 gap-6 items-start">

      <!-- Trademap — featured card, takes 2 cols -->
      <div class="card p-8 lg:col-span-2 border-gold-400/20 relative overflow-hidden">
        <!-- Background glow -->
        <div class="absolute top-0 right-0 w-64 h-64 rounded-full pointer-events-none"
          style="background: radial-gradient(ellipse at top right, rgba(245,166,35,0.06) 0%, transparent 70%);">
        </div>

        <div class="relative">
          <!-- Status badge -->
          <div class="mb-5 inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-gold-400/10 border border-gold-400/20">
            <span class="w-1.5 h-1.5 rounded-full bg-gold-400 animate-pulse"></span>
            <span class="font-mono text-xs text-gold-400 tracking-widest uppercase">Active · Personal Project</span>
          </div>

          <h3 class="text-2xl font-bold text-[#E8E8E8] mb-2">Trademap</h3>
          <p class="text-gold-400 text-sm font-medium mb-4">Trade Journal & Learning Platform</p>

          <p class="text-[#888] text-sm leading-relaxed mb-6">
            A personal platform built to bring structure to the learning journey in trading.
            Trademap combines a <span class="text-[#E8E8E8]">trade journal</span> with a knowledge base —
            documenting strategies, technical analysis, mindset frameworks, and psychology lessons
            all in one place. The goal: make improvement measurable, not just felt.
          </p>

          <!-- Feature list -->
          <div class="grid sm:grid-cols-2 gap-3 mb-6">
            {[
              { icon: "📓", label: "Trade Journal", desc: "Log, review, and reflect on every trade" },
              { icon: "📊", label: "Strategy Docs", desc: "Demand & Supply setups and playbooks" },
              { icon: "🧠", label: "Mindset & Psychology", desc: "Documented lessons on discipline and bias" },
              { icon: "📈", label: "Technical Analysis", desc: "Chart patterns, confluences, and frameworks" },
            ].map(f => (
              <div class="flex items-start gap-3 p-3 rounded-lg bg-surface-700/50">
                <span class="text-base mt-0.5">{f.icon}</span>
                <div>
                  <div class="text-xs font-semibold text-[#E8E8E8] mb-0.5">{f.label}</div>
                  <div class="text-xs text-muted leading-relaxed">{f.desc}</div>
                </div>
              </div>
            ))}
          </div>

          <!-- Tags + link -->
          <div class="flex flex-wrap items-center justify-between gap-4">
            <div class="flex flex-wrap gap-2">
              {["Trading", "Demand & Supply", "Psychology", "React", "Trading Journal"].map(t => (
                <span class="tag">{t}</span>
              ))}
            </div>
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-surface-500 text-muted text-xs font-mono cursor-default">
              🚧 In Development
            </span>
          </div>
        </div>
      </div>

      <!-- Right column: side cards -->
      <div class="flex flex-col gap-6">

        <!-- Professional work card -->
        <div class="card p-6">
          <div class="w-10 h-10 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-xl mb-4">
            🏗️
          </div>
          <h3 class="text-[#E8E8E8] font-semibold mb-2">Professional Work</h3>
          <p class="text-[#888] text-sm leading-relaxed">
            Enterprise-scale data platforms at L'Oréal — ingestion services, DQ pipelines, and cloud-native APIs.
            Internal projects under NDA.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            {["GCP", "BigQuery", "FastAPI", "React"].map(t => (
              <span class="tag">{t}</span>
            ))}
          </div>
        </div>

        <!-- More coming card -->
        <div class="card p-6 border-dashed border-surface-500 flex flex-col items-center text-center">
          <div class="w-10 h-10 rounded-xl bg-surface-700 flex items-center justify-center text-xl mb-3">
            ✦
          </div>
          <p class="text-muted text-sm">More projects in the pipeline.</p>
          <p class="text-xs text-surface-500 mt-1 font-mono">Building in public — soon.</p>
        </div>

      </div>
    </div>
  </div>
</section>
